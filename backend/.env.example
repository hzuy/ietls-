# Database (lấy từ Supabase > Project Settings > Database > Connection string > URI)
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# JWT (tạo chuỗi random bất kỳ, vd: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-here"

# Groq AI (lấy từ console.groq.com)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxx"

# URL frontend sau khi deploy lên Vercel (điền sau khi deploy frontend xong)
FRONTEND_URL="https://your-app.vercel.app"

# Port (Render tự set, không cần đổi)
PORT=3001
